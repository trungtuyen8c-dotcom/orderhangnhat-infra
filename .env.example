# ===== App =====
APP_DOMAIN=localhost
NODE_ENV=production

# ===== Postgres =====
POSTGRES_USER=orderhn
POSTGRES_PASSWORD=change_me_pg
POSTGRES_DB=orderhn
# DSN dùng bởi backend (host = service name trong docker network)
DATABASE_URL=postgresql://orderhn:change_me_pg@postgres:5432/orderhn?schema=public

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== MinIO =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=orderhn
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false

# ===== Auth =====
JWT_SECRET=change_me_to_a_long_random_secret
ACCESS_TOKEN_TTL=900            # 15 phút (giây)
REFRESH_TOKEN_TTL=604800        # 7 ngày (giây)

# ===== Frontend =====
VITE_API_BASE=/api
